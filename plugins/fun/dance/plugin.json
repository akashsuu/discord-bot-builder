{
 "name": "Anime Dance",
 "version": "1.0.0",
 "description": "Fetches an anime dance GIF from nekos.best and sends a rich purple embed showing who danced with whom.",
 "author": "Akashsuu",
 "icon": "DNC",
 "nodeConfig": {
 "label": "Anime Dance",
 "icon": "DNC",
 "color": "#7B2FBE",
 "hasInput": true,
 "hasOutput": true,
 "defaults": {
 "command": "dance",
 "apiUrl": "https://nekos.best/api/v2/dance",
 "embedEnabled": true,
 "embedColor": "#7B2FBE",
 "titleTemplate": "{author} danced with {target}!",
 "descriptionTemplate": "**{author}** is dancing with **{target}**!",
 "plainTextTemplate": "**{author}** is dancing with **{target}**! {gif}",
 "noTargetMessage": "❌ You need to mention someone to dance with! Usage: `{command} @user`",
 "errorMessage": "❌ Could not fetch a dance GIF. Try again later."
 },
 "fields": [
 {
 "key": "command",
 "label": "Command",
 "type": "text",
 "placeholder": "dance"
 },
 {
 "key": "apiUrl",
 "label": "GIF API URL",
 "type": "text",
 "placeholder": "https://nekos.best/api/v2/dance"
 },
 {
 "key": "embedEnabled",
 "label": "Enable Embed",
 "type": "checkbox"
 },
 {
 "key": "embedColor",
 "label": "Embed Color",
 "type": "color"
 },
 {
 "key": "titleTemplate",
 "label": "Embed Title",
 "type": "text"
 },
 {
 "key": "descriptionTemplate",
 "label": "Embed Description",
 "type": "text"
 },
 {
 "key": "plainTextTemplate",
 "label": "Plain Text",
 "type": "text"
 },
 {
 "key": "noTargetMessage",
 "label": "No Target Message",
 "type": "text"
 },
 {
 "key": "errorMessage",
 "label": "Error Message",
 "type": "text"
 }
 ]
 }
}
