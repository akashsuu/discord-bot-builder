{
 "name": "kiodium",
 "version": "1.0.0",
 "description": "Kiodium visual Discord bot builder",
 "main": "main.js",
 "scripts": {
  "build": "webpack --mode development",
 "start": "npm run build && node launch.js",
 "dev": "npm run build && node launch.js",
  "watch": "webpack --watch --mode development",
  "set-icon": "node scripts/set-icon.js release-selection",
  "pack-asar": "node scripts/pack-asar.js release-selection",
  "dist": "npm run build && cross-env ELECTRON_BUILDER_CACHE=.electron-builder-cache electron-builder --win --x64 --dir && npm run set-icon && npm run pack-asar"
 },
 "dependencies": {
  "@discordjs/voice": "^0.18.0",
  "@distube/youtube": "^1.0.4",
  "@tailwindcss/postcss": "^4.2.4",
  "autoprefixer": "^10.5.0",
  "clsx": "^2.1.1",
  "discord.js": "^14.14.1",
  "distube": "^5.0.7",
  "ffmpeg-static": "^5.1.0",
  "figlet": "^1.11.0",
  "framer-motion": "^12.38.0",
  "jimp": "^1.6.1",
  "lucide-react": "^1.14.0",
  "opusscript": "^0.1.1",
  "postcss": "^8.5.14",
  "postcss-loader": "^8.2.1",
  "react": "^18.2.0",
  "react-dom": "^18.2.0",
  "reactflow": "^11.11.3",
  "tailwind-merge": "^3.5.0",
  "tailwindcss": "^3.4.1"
 },
 "devDependencies": {
  "@babel/core": "^7.23.9",
  "@babel/preset-env": "^7.23.9",
  "@babel/preset-react": "^7.23.3",
  "babel-loader": "^9.1.3",
  "cross-env": "^10.1.0",
  "css-loader": "^6.10.0",
  "electron": "^28.2.3",
  "electron-builder": "^26.8.1",
  "html-webpack-plugin": "^5.6.0",
  "style-loader": "^3.3.4",
  "webpack": "^5.90.3",
  "webpack-cli": "^5.1.4"
 },
 "build": {
  "appId": "com.kiodium.app",
  "productName": "Kiodium",
  "asar": false,
  "electronDist": ".electron-dist-clean",
  "directories": {
   "output": "release-selection"
  },
  "files": [
   "dist/**/*",
   "backend/**/*",
   "plugins/**/*",
   "data/**/*",
   "main.js",
   "preload.js",
   "launch.js",
   "package.json",
   "kiodium.ico"
  ],
  "win": {
   "icon": "kiodium.ico",
   "signAndEditExecutable": false,
   "target": [
    "portable",
    "nsis"
   ]
  },
  "nsis": {
   "oneClick": false,
   "allowToChangeInstallationDirectory": true
  }
 }
}
