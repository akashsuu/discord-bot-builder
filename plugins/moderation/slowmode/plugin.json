{
  "name": "Slowmode",
  "version": "1.0.0",
  "description": "Prefix command to set channel slowmode duration.",
  "author": "Akashsuu",
  "icon": "SM",
  "nodeConfig": {
    "label": "Slowmode",
    "icon": "SM",
    "color": "#B91C1C",
    "hasInput": true,
    "hasOutput": true,
    "defaults": {
      "command": "slowmode",
      "defaultSeconds": 10,
      "output": "{mention} set slowmode in {channelMention} to **{seconds}s**.",
      "embedEnabled": false,
      "embedColor": "#8B5CF6"
    }
  }
}
