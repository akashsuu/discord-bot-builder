{
 "name": "Random Joke",
 "version": "1.0.0",
 "description": "Fetches a random joke from official-joke-api and sends it as message or embed.",
 "author": "Akashsuu",
 "icon": "JK",
 "nodeConfig": {
 "label": "Random Joke",
 "icon": "JK",
 "color": "#F59E0B",
 "hasInput": true,
 "hasOutput": true,
 "defaults": {
 "command": "joke",
 "apiUrl": "https://official-joke-api.appspot.com/random_joke",
 "embedEnabled": true,
 "embedColor": "#F59E0B",
 "titleTemplate": "{author} asked for a joke!",
 "descriptionTemplate": "{setup}\n\n{punchline}",
 "plainTextTemplate": "{setup}\n{punchline}",
 "footerTemplate": "Type: {type}",
 "errorMessage": "❌ Could not fetch a joke. Try again later."
 },
 "fields": [
 {
 "key": "command",
 "label": "Command",
 "type": "text",
 "placeholder": "joke"
 },
 {
 "key": "apiUrl",
 "label": "Joke API URL",
 "type": "text",
 "placeholder": "https://official-joke-api.appspot.com/random_joke"
 },
 {
 "key": "embedEnabled",
 "label": "Enable Embed",
 "type": "checkbox"
 },
 {
 "key": "embedColor",
 "label": "Embed Color",
 "type": "color"
 },
 {
 "key": "titleTemplate",
 "label": "Embed Title",
 "type": "text"
 },
 {
 "key": "descriptionTemplate",
 "label": "Embed Description",
 "type": "text"
 },
 {
 "key": "plainTextTemplate",
 "label": "Plain Text",
 "type": "text"
 },
 {
 "key": "footerTemplate",
 "label": "Embed Footer",
 "type": "text"
 },
 {
 "key": "errorMessage",
 "label": "Error Message",
 "type": "text"
 }
 ]
 }
}
