{
  "name": "Music Play",
  "version": "1.0.0",
  "description": "Play a song using Lavalink / YouTube search with player controls.",
  "author": "Akashsuu",
  "icon": "PLY",
  "nodeConfig": {
    "label": "Music Play",
    "icon": "PLY",
    "color": "#5865F2",
    "hasInput": true,
    "hasOutput": true,
    "defaults": {
      "command": "play",
      "aliases": "p",
      "lavalinkUrl": "",
      "lavalinkHost": "localhost",
      "lavalinkPort": "2333",
      "lavalinkPassword": "youshallnotpass",
      "lavalinkSecure": false,
      "youtubeSearchPrefix": "ytsearch:",
      "fallbackSearchPrefixes": "ytsearch:,ytmsearch:,scsearch:",
      "volume": "100",
      "nowPlayingTitle": "{title}",
      "artistTemplate": "{author}",
      "durationTemplate": "{duration}",
      "queuedMessage": "Added **{title}** to the queue.",
      "missingQueryMessage": "Use `{command} <song name or url>` to play music.",
      "missingVoiceMessage": "Join a voice channel first.",
      "noResultsMessage": "No tracks found for `{query}`.",
      "lavalinkErrorMessage": "Music playback failed. Details: {error}",
      "completedMessage": "Use `{command}` to add more songs to the queue",
      "shuffleButtonLabel": "Shuffle",
      "previousButtonLabel": "Previous",
      "pauseButtonLabel": "Pause",
      "resumeButtonLabel": "Resume",
      "skipButtonLabel": "Skip",
      "queueButtonLabel": "Queue",
      "autoplayButtonLabel": "Start Autoplay",
      "restartButtonLabel": "Restart Queue",
      "disconnectButtonLabel": "Disconnect bot",
      "playlistsButtonLabel": "Playlists",
      "browseButtonLabel": "Browse",
      "settingsButtonLabel": "Settings",
      "embedEnabled": true,
      "embedColor": "#2B2D31",
      "embedTitle": "Now Playing",
      "embedFooter": "Requested by {user}",
      "logoUrl": "",
      "logoName": "",
      "imageUrl": "",
      "imagePosition": "bottom"
    }
  }
}
