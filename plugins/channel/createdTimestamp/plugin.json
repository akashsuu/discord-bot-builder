{
  "name": "Create Timestamp",
  "version": "1.0.0",
  "description": "Generates a Discord timestamp",
  "author": "Akashsuu",
  "icon": "⏱️",
  "nodeConfig": {
    "label": "Create Timestamp",
    "icon": "⏱️",
    "color": "#3A3A5A",
    "hasInput": true,
    "hasOutput": true,
    "defaults": {
      "timeOffset": "0",
      "format": "F",
      "saveAs": "timestamp",
      "output": "⏱️ Time: {timestamp}",
      "useEmbed": true,
      "color": "#5865F2"
    }
  }
}