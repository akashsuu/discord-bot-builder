{
  "name": "Anime Slap",
  "version": "1.0.0",
  "description": "Fetches an anime slap GIF from nekos.best and sends a rich purple embed showing who slapped whom.",
  "author": "Akashsuu",
  "icon": "👋",
  "nodeConfig": {
    "label": "Anime Slap",
    "icon": "👋",
    "color": "#7B2FBE",
    "hasInput": true,
    "hasOutput": true,
    "defaults": {
      "command": "slap",
      "embedColor": "#7B2FBE",
      "noTargetMessage": "❌ You need to mention someone to slap! Usage: `{command} @user`",
      "errorMessage": "❌ Could not fetch a slap GIF. Try again later."
    },
    "fields": [
      {
        "key": "command",
        "label": "Command",
        "type": "text",
        "placeholder": "slap"
      },
      {
        "key": "embedColor",
        "label": "Embed Color",
        "type": "color"
      },
      {
        "key": "noTargetMessage",
        "label": "No Target Message",
        "type": "text"
      },
      {
        "key": "errorMessage",
        "label": "Error Message",
        "type": "text"
      }
    ]
  }
}
